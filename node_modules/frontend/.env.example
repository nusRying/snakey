# Used by Vite to configure the backend websocket origin in production
VITE_BACKEND_URL=https://snakey-backend.up.railway.app

# Optional GA4/Firebase-compatible measurement id for third-party analytics events.
VITE_FIREBASE_MEASUREMENT_ID=

# Optional Android monetization ids. If blank, the app falls back to Google test ad ids.
VITE_ADMOB_APP_ID_ANDROID=
VITE_ADMOB_BANNER_ID_ANDROID=
VITE_ADMOB_INTERSTITIAL_ID_ANDROID=
VITE_ADMOB_REWARDED_ID_ANDROID=
